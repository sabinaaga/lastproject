@using Fiorello.ViewModels
@model IEnumerable<BlogVM>

@foreach (var item in Model)
{
    <div class="col-md-6 col-lg-4 mb-4">
        <a asp-controller="Blog"
           asp-action="Details"
           asp-route-id="@item.Id"
           class="text-decoration-none text-dark">

            <div class="item">
                <div class="img position-relative">
                    <img src="img/@item.ImageUrl" class="img-fluid" alt="">
                    <div class="date rounded bg-light position-absolute py-1 px-2">
                        <span>@item.CreatedAt.ToString("dd MMM yyyy")</span>
                    </div>
                </div>

                <div class="text mt-3 text-center px-3">
                    <h5>@item.Title</h5>
                    <p class="text-black-50">@item.Description</p>
                </div>
            </div>

        </a>
    </div>
}

