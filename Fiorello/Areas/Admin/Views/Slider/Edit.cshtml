@using Fiorello.Areas.Admin.ViewModels.Slider
@model SliderEditVM



<div class="container mt-5">

    <div class="image">
        <img src="~/img/@Model.ExistImage" style="width:200px; height:150px" />

    </div>

    <form class="form-inline" method="post" asp-action="Edit" enctype="multipart/form-data">
        <div class="form-group">
            <label for="name">Slider</label>
            <input type="file" class="form-control" id="name" asp-for="UploadImage" multiple><br />
            <span asp-validation-for="UploadImage" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary mt-5">Submit</button>
        <a asp-action="Index" class="btn btn-light mt-5">Cancel</a>

    </form>

</div>










