 @using Fiorello.Areas.Admin.ViewModels.Product
@model ProductEditVM

<div class="container mt-5">
    <div class="row">

        @foreach (var item in Model.ProductImages)
        {
            <div class="col-3 d-flex justify-content-center">

              
                    <div class="@(item.Main ? "edit-main-product" : "")"
                         style="position:relative; width:100%;">

                  <div style="position:absolute;
                                top:50%;
                                left:50%;
                                transform:translate(-50%,-50%);
                                display:flex;
                                gap:10px;">

                        <div class="buttons" data-id="@item.Id">

                        <button class="delete-btn @(item.Main ? "d-none" : "btn btn-danger")">Delete</button>
                        <button class="ismain-btn @(item.Main ? "d-none" : "btn btn-success")">IsMain</button>
                        </div>

                        </div>
                

                        <img src="~/img/@item.Name"
                             style="width:100%; height:250px; object-fit:cover;" />

                    </div>
               
                 
            </div>
        }

    </div>
</div> 
<div class="container mt-5">

    <form class="form-inline" method="post" asp-action="Edit" enctype="multipart/form-data">

        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="form-group">
            <label for="name">Product</label>

            <div class="form-group">
                <label for="ProductName">Product Images</label>
                <input type="file" class="form-control mt-3" asp-for="Images" multiple><br />
                <span asp-validation-for="Images" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="Name">Product Name</label>
                <input type="text" class="form-control" asp-for="Name"><br />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="ProductName">Product Price</label>
                <input type="text" class="form-control" asp-for="Price"><br />
                <span asp-validation-for="Price" class="text-danger"></span>

            </div>
            <div class="form-group">
                <label for="CategoryId">Category</label>
                <select asp-for="CategoryId" asp-items="@ViewBag.categories" class="form-control">
                    <option>-- Select category --</option>
                </select>
            </div>
        </div>

        <button type="submit" class="btn btn-primary mt-5">Submit</button>
        <a asp-action="Index" class="btn btn-light mt-5">Cancel</a>
    </form>
</div>


