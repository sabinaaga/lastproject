@model IEnumerable<Fiorello.Areas.Admin.ViewModels.Product.ProductAdminVM>


<div class="container-fluid mt-3">
    <h1 class="mt-30 " style="color:red">Sliders</h1>
    <div class="table-responsive">
        <a asp-action="Create" type="button" class="btn btn-success">Create</a>
        <table class="table table-hover">
            <thead class="">
            <th>
                Name
            </th>
            <th>
                Price
            </th>
            <th>
                Category
            </th>
            <th>
                Image
            </th>
            <th>
                Options
            </th>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <h3 class="mt-30 " style="color:black; font-size:14px;">@item.Name</h3>


                        </td>
                        <td>
                            <h3 class="mt-30 " style="color:black; font-size:14px;">@item.Price</h3>


                        </td>
                        <td>
                            <h3 class="mt-30 " style="color:black; font-size:14px;">@item.CategoryName</h3>

                        </td>
                        <td>
@*                             <img src="~/img/@item.ProductImages.FirstOrDefault(b => b.Main).Name" style="width:200px; height:150px" />
 *@
                            @{
                                string image = item.ProductImages
                                .FirstOrDefault(b => b.Main)?.Name ?? "default.jpg";
                            }

                            <img src="~/img/@image"
                                 style="width:200px; height:150px" />

                        </td>
                       
                     
                        <td>
                            <a asp-action="Detail" asp-route-id="@item.Id" type="button" class="btn btn-info">Detail</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" type="button" class="btn btn-primary">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

